{
  "name": "quarter-tone-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "Quarter Tone arcade — root workspace.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm -w @quarter-tone/core run build",
    "test": "npm -w @quarter-tone/core run test",
    "test:coverage": "npm -w @quarter-tone/core run test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "typecheck": "npm -w @quarter-tone/core run typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
