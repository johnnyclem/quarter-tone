{
  "name": "quarter-tone-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "Quarter Tone arcade — root workspace.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w @quarter-tone/app run dev",
    "build": "npm -w @quarter-tone/core run build && npm -w @quarter-tone/app run build",
    "preview": "npm -w @quarter-tone/app run preview",
    "test": "npm -w @quarter-tone/core run test",
    "test:coverage": "npm -w @quarter-tone/core run test:coverage",
    "typecheck": "npm -w @quarter-tone/core run typecheck && npm -w @quarter-tone/app run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0"
  }
}
