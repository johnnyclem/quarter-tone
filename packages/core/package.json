{
  "name": "@quarter-tone/core",
  "version": "0.1.0",
  "description": "Core music theory (ScaleMapper) and arcade game modules for Quarter Tone.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scale-mapper": {
      "types": "./dist/scale-mapper.d.ts",
      "import": "./dist/scale-mapper.js"
    },
    "./synth-store": {
      "types": "./dist/synth-store.d.ts",
      "import": "./dist/synth-store.js"
    },
    "./games": {
      "types": "./dist/games/index.d.ts",
      "import": "./dist/games/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "music",
    "scale",
    "arcade",
    "games",
    "synth",
    "quarter-tone"
  ],
  "dependencies": {
    "zustand": "^5.0.12"
  }
}
